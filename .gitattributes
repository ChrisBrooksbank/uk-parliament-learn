# Auto detect text files and normalise line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.svg text eol=lf

# Denote binary files
*.png binary
*.jpg binary
*.ico binary
*.woff2 binary
